# ============================================================
#  Buddy Script — environment variables
#  Copy the API block to  api/.env  and the WEB block to  web/.env.local
# ============================================================

# ---------------------- API (api/.env) ----------------------

# PostgreSQL connection string.
# Local docker-compose default is below. For Neon/production use the POOLED
# connection string (append ?pgbouncer=true&connection_limit=1 on serverless).
DATABASE_URL="postgresql://buddy:buddy@localhost:5432/buddy_script?schema=public"

# JWT signing
JWT_SECRET="change-me-to-a-long-random-secret"
JWT_EXPIRES_IN="7d"

# Auth cookie
COOKIE_NAME="bs_token"
COOKIE_SECURE="false"        # "true" in production (https only)
COOKIE_SAMESITE="lax"        # "none" for split-domain deploy (requires COOKIE_SECURE=true)
COOKIE_DOMAIN=""             # leave blank for localhost

# CORS — the web origin (only needed for the split-domain deploy; the Next.js
# rewrite proxy makes requests same-origin so CORS is not exercised in dev).
WEB_ORIGIN="http://localhost:3000"

# API server port
API_PORT="4000"

# Cloudflare R2 (S3-compatible object storage for post images)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="buddy-script"
R2_PUBLIC_BASE_URL=""        # e.g. https://pub-xxxxx.r2.dev  or your custom domain

# -------------------- WEB (web/.env.local) ------------------

# Base URL of the NestJS API. Next.js rewrites /api/* to ${API_URL}/api/*
# so the browser only ever talks to the web origin (clean first-party cookies).
API_URL="http://localhost:4000"
